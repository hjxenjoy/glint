{
  "name": "glint",
  "version": "1.0.0",
  "description": "一个个闪光的创意片段 — 静态 HTML Demo 管理与预览工具",
  "scripts": {
    "format": "prettier --write \"**/*.{html,css,js,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{html,css,js,json}\" --ignore-path .gitignore",
    "prepare": "node scripts/setup-hooks.js"
  },
  "lint-staged": {
    "*.{html,css,js,json}": [
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
